<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="OwnerAI.Host.Desktop.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:OwnerAI.Host.Desktop.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- 全局颜色 -->
            <SolidColorBrush x:Key="OwnerAIPrimaryBrush" Color="#6366F1" />
            <SolidColorBrush x:Key="OwnerAIAccentBrush" Color="#8B5CF6" />
            <SolidColorBrush x:Key="UserBubbleBrush" Color="#6366F1" />
            <SolidColorBrush x:Key="AssistantBubbleBrush" Color="#374151" />
            <SolidColorBrush x:Key="DelegationBubbleBrush" Color="#0E7490" />
            <SolidColorBrush x:Key="SecondaryBubbleBrush" Color="#7C3AED" />

            <!-- 转换器 -->
            <conv:BoolToAlignmentConverter x:Key="BoolToAlignment" />
            <conv:BoolToBubbleBrushConverter
                x:Key="BoolToBubbleBrush"
                UserBrush="{StaticResource UserBubbleBrush}"
                AssistantBrush="{StaticResource AssistantBubbleBrush}" />
            <conv:ChatRoleToBrushConverter
                x:Key="ChatRoleToBrush"
                UserBrush="{StaticResource UserBubbleBrush}"
                AssistantBrush="{StaticResource AssistantBubbleBrush}"
                DelegationBrush="{StaticResource DelegationBubbleBrush}"
                SecondaryBrush="{StaticResource SecondaryBubbleBrush}" />
            <conv:AttachmentKindToVisibilityConverter x:Key="AttachmentKindToVisibility" />
            <conv:StringToImageSourceConverter x:Key="StringToImageSource" />
            <conv:StringToMediaSourceConverter x:Key="StringToMediaSource" />

            <!-- 调度器转换器 -->
            <conv:TaskStatusToGlyphConverter x:Key="TaskStatusToGlyph" />
            <conv:TaskStatusToBrushConverter x:Key="TaskStatusToBrush" />
            <conv:TaskStatusToVisibilityConverter x:Key="TaskStatusToVisibility" />
            <conv:TaskStatusToLabelConverter x:Key="TaskStatusToLabel" />
            <conv:TaskStatusToBadgeBrushConverter x:Key="TaskStatusToBadgeBrush" />
            <conv:StringToBrushConverter x:Key="SecurityColorToBrush" />
            <conv:BoolToOpacityConverter x:Key="SkillEnabledToOpacity" />
            <conv:IntToVisibilityConverter x:Key="IntToVisibility" />
            <conv:BoolToDuplicateBrushConverter x:Key="DuplicateBorderBrush" />
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
