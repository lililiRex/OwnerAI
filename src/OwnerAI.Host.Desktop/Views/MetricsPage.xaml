<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OwnerAI.Host.Desktop.Views.MetricsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:OwnerAI.Host.Desktop.ViewModels"
    NavigationCacheMode="Enabled">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="20" MaxWidth="900">

            <!-- 页面标题 + 刷新 -->
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="4">
                    <TextBlock Text="度量面板" FontSize="28" FontWeight="Bold" />
                    <TextBlock Text="进化度量 &amp; 模型调用统计" Opacity="0.6" FontSize="13" />
                </StackPanel>
                <Button Grid.Column="1" VerticalAlignment="Top"
                        Command="{x:Bind ViewModel.RefreshCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE72C;" FontSize="14" />
                        <TextBlock Text="刷新" />
                    </StackPanel>
                </Button>
            </Grid>

            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          Width="32" Height="32" HorizontalAlignment="Center" />

            <!-- ══════ 进化度量 ══════ -->
            <TextBlock Text="🧬 进化度量" FontSize="18" FontWeight="SemiBold" Margin="0,8,0,0" />

            <!-- 缺口概览卡片 -->
            <Grid ColumnDefinitions="*,*,*,*,*" ColumnSpacing="12">
                <!-- 总计 -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16">
                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                        <TextBlock Text="总缺口" FontSize="12" Opacity="0.6" HorizontalAlignment="Center" />
                        <TextBlock Text="{x:Bind ViewModel.TotalGaps, Mode=OneWay}" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
                <!-- 已解决 -->
                <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16">
                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                        <TextBlock Text="已解决" FontSize="12" Opacity="0.6" HorizontalAlignment="Center" Foreground="Green" />
                        <TextBlock Text="{x:Bind ViewModel.ResolvedGaps, Mode=OneWay}" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
                <!-- 进行中 -->
                <Border Grid.Column="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16">
                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                        <TextBlock Text="进行中" FontSize="12" Opacity="0.6" HorizontalAlignment="Center" />
                        <TextBlock Text="{x:Bind ViewModel.InProgressGaps, Mode=OneWay}" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
                <!-- 待处理 -->
                <Border Grid.Column="3" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16">
                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                        <TextBlock Text="待处理" FontSize="12" Opacity="0.6" HorizontalAlignment="Center" />
                        <TextBlock Text="{x:Bind ViewModel.PendingGaps, Mode=OneWay}" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
                <!-- 失败 -->
                <Border Grid.Column="4" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16">
                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                        <TextBlock Text="失败" FontSize="12" Opacity="0.6" HorizontalAlignment="Center" Foreground="OrangeRed" />
                        <TextBlock Text="{x:Bind ViewModel.FailedGaps, Mode=OneWay}" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 进化 ROI 度量 -->
            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="12">
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Token 总消耗" FontSize="12" Opacity="0.6" />
                        <TextBlock Text="{x:Bind ViewModel.TotalTokenCost, Mode=OneWay}" FontSize="20" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="每解决 Token" FontSize="12" Opacity="0.6" />
                        <TextBlock Text="{x:Bind ViewModel.AvgTokenPerResolved, Mode=OneWay}" FontSize="20" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="验收通过率" FontSize="12" Opacity="0.6" />
                        <TextBlock FontSize="20" FontWeight="SemiBold">
                            <Run Text="{x:Bind ViewModel.AcceptancePassRate, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="平均解决时间" FontSize="12" Opacity="0.6" />
                        <TextBlock Text="{x:Bind ViewModel.AvgResolutionTimeText, Mode=OneWay}" FontSize="20" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </Grid>

            <TextBlock Opacity="0.5" FontSize="12">
                <Run Text="最近进化: " />
                <Run Text="{x:Bind ViewModel.LastEvolutionText, Mode=OneWay}" />
            </TextBlock>

            <!-- ══════ 模型调用度量 ══════ -->
            <TextBlock Text="📊 模型调用度量" FontSize="18" FontWeight="SemiBold" Margin="0,12,0,0" />

            <!-- 模型总览 -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="总调用次数 (30天)" FontSize="12" Opacity="0.6" />
                        <TextBlock Text="{x:Bind ViewModel.TotalModelCalls, Mode=OneWay}" FontSize="28" FontWeight="Bold" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="总 Token 消耗 (30天)" FontSize="12" Opacity="0.6" />
                        <TextBlock Text="{x:Bind ViewModel.TotalModelTokens, Mode=OneWay}" FontSize="28" FontWeight="Bold" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 模型明细表 -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="各模型分类明细" FontWeight="SemiBold" FontSize="14" />
                    <!-- 表头 -->
                    <Grid ColumnDefinitions="2*,1.5*,80,80,80,80" Padding="4,0">
                        <TextBlock Text="模型" FontSize="12" FontWeight="SemiBold" Opacity="0.7" />
                        <TextBlock Grid.Column="1" Text="分类" FontSize="12" FontWeight="SemiBold" Opacity="0.7" />
                        <TextBlock Grid.Column="2" Text="调用" FontSize="12" FontWeight="SemiBold" Opacity="0.7" HorizontalAlignment="Right" />
                        <TextBlock Grid.Column="3" Text="成功率" FontSize="12" FontWeight="SemiBold" Opacity="0.7" HorizontalAlignment="Right" />
                        <TextBlock Grid.Column="4" Text="延迟" FontSize="12" FontWeight="SemiBold" Opacity="0.7" HorizontalAlignment="Right" />
                        <TextBlock Grid.Column="5" Text="Token" FontSize="12" FontWeight="SemiBold" Opacity="0.7" HorizontalAlignment="Right" />
                    </Grid>
                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                    <!-- 数据行 -->
                    <ItemsControl ItemsSource="{x:Bind ViewModel.ModelMetrics, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ModelMetricRow">
                                <Grid ColumnDefinitions="2*,1.5*,80,80,80,80" Padding="4,6">
                                    <TextBlock Text="{x:Bind ProviderName}" FontSize="12" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind WorkCategory}" FontSize="12" Opacity="0.7" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="2" Text="{x:Bind TotalCalls}" FontSize="12" HorizontalAlignment="Right" />
                                    <TextBlock Grid.Column="3" Text="{x:Bind SuccessRateText}" FontSize="12" HorizontalAlignment="Right" />
                                    <TextBlock Grid.Column="4" Text="{x:Bind LatencyText}" FontSize="12" HorizontalAlignment="Right" />
                                    <TextBlock Grid.Column="5" Text="{x:Bind TotalTokens}" FontSize="12" HorizontalAlignment="Right" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
