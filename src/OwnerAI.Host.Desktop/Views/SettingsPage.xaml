<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OwnerAI.Host.Desktop.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:OwnerAI.Host.Desktop.Models">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="16" MaxWidth="700">

            <TextBlock Text="设置" Style="{StaticResource TitleTextBlockStyle}" />

            <!-- ===== 模型供应商 ===== -->
            <TextBlock Text="模型供应商" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,16,0,4" />
            <TextBlock Text="配置 AI 模型连接。每个模型可指定类别和角色，主模型负责对话，次级模型接受专项任务分发。"
                       Opacity="0.6" FontSize="13" TextWrapping="Wrap" />

            <ItemsRepeater ItemsSource="{x:Bind ViewModel.Providers}">
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="models:ProviderConfigItem">
                        <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,8">
                            <StackPanel Spacing="8">
                                <Grid ColumnDefinitions="*,Auto,Auto">
                                    <ComboBox Header="供应商类型" Width="280"
                                              ItemsSource="{x:Bind models:ProviderConfigItem.Presets}"
                                              DisplayMemberPath="DisplayName"
                                              SelectedItem="{x:Bind SelectedPreset, Mode=TwoWay}" />
                                    <Button Grid.Column="1" VerticalAlignment="Bottom"
                                            Margin="8,0,0,0" Padding="8,6"
                                            ToolTipService.ToolTip="测试模型调用"
                                            Click="OnTestProviderClick"
                                            Tag="{x:Bind}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE895;" FontSize="14" />
                                            <TextBlock Text="测试" />
                                        </StackPanel>
                                    </Button>
                                    <Button Grid.Column="2" VerticalAlignment="Bottom"
                                            Margin="8,0,0,0" Padding="8,6"
                                            ToolTipService.ToolTip="删除"
                                            Click="OnRemoveProviderClick"
                                            Tag="{x:Bind}">
                                        <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                    </Button>
                                </Grid>
                                <PasswordBox Header="API Key" Password="{x:Bind ApiKey, Mode=TwoWay}"
                                             PlaceholderText="{x:Bind ApiKeyPlaceholder, Mode=OneWay}" />
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                    <TextBox Header="API 端点" Text="{x:Bind Endpoint, Mode=TwoWay}"
                                             PlaceholderText="https://..." />
                                    <TextBox Grid.Column="1" Header="模型 ID" Text="{x:Bind ModelId, Mode=TwoWay}"
                                             PlaceholderText="模型名称" />
                                </Grid>
                                <!-- 模型类别(多选标签) + 角色 + 名称 + 优先级 -->
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <StackPanel>
                                        <TextBlock Text="模型类别（多选）" Style="{ThemeResource CaptionTextBlockStyle}" Margin="0,0,0,4" />
                                        <TextBlock Text="{x:Bind CategoriesDisplay, Mode=OneWay}"
                                                   FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <ComboBox Grid.Column="1" Header="模型角色" Width="200"
                                              ItemsSource="{x:Bind models:ProviderConfigItem.RoleDisplayItems}"
                                              DisplayMemberPath="Display"
                                              SelectedItem="{x:Bind SelectedRoleItem, Mode=TwoWay}" />
                                </Grid>
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <TextBox Header="显示名称" Text="{x:Bind Name, Mode=TwoWay}"
                                             PlaceholderText="自定义名称" />
                                    <NumberBox Grid.Column="1" Header="优先级"
                                               Value="{x:Bind Priority, Mode=TwoWay}"
                                               Minimum="0" Maximum="99"
                                               SpinButtonPlacementMode="Compact"
                                               Width="120" />
                                </Grid>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <ProgressRing IsActive="{x:Bind IsConnectionTestRunning, Mode=OneWay}" Width="14" Height="14" />
                                    <TextBlock Text="{x:Bind ConnectionTestStatus, Mode=OneWay}"
                                               FontSize="12" Opacity="0.7" TextWrapping="Wrap" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <Button Command="{x:Bind ViewModel.AddProviderCommand}" Margin="0,4,0,0">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE710;" FontSize="14" />
                    <TextBlock Text="添加供应商" />
                </StackPanel>
            </Button>

            <!-- ===== 多模型编排总览 ===== -->
            <TextBlock Text="多模型编排" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,16,0,4" />
            <TextBlock Text="主模型负责对话和任务分析，自动将专业任务分发给对应类别的次级模型执行。"
                       Opacity="0.6" FontSize="13" TextWrapping="Wrap" />

            <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,8">
                <StackPanel Spacing="6">
                    <Grid ColumnDefinitions="140,*" Margin="0,0,0,4">
                        <TextBlock Text="类别" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="1" Text="已分配模型" FontWeight="SemiBold" />
                    </Grid>
                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,0,0,4" />

                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.ModelSlotSummaries, Mode=OneWay}">
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="models:ModelSlotSummary">
                                <Grid ColumnDefinitions="140,*" Padding="0,3">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="{x:Bind Icon}" FontSize="16" />
                                        <TextBlock Text="{x:Bind CategoryName}" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1"
                                               Text="{x:Bind AssignedModel}"
                                               Opacity="{x:Bind AssignedOpacity}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>
            </Border>

            <!-- ===== 工作分类模型路由 ===== -->
            <TextBlock Text="工作分类模型路由" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,16,0,4" />
            <TextBlock Text="按实际工作流为聊天、代码、进化规划/执行/验收、视觉等槽位单独绑定模型。未指定时将自动按类别回退。"
                       Opacity="0.6" FontSize="13" TextWrapping="Wrap" />

            <ItemsRepeater ItemsSource="{x:Bind ViewModel.WorkModelSlots, Mode=OneWay}">
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="models:WorkModelSlotItem">
                        <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,8">
                            <Grid ColumnDefinitions="*,260" ColumnSpacing="16">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Bind SlotName}" FontSize="14" FontWeight="SemiBold" />
                                    <TextBlock Text="{x:Bind Description}" FontSize="12" Opacity="0.65" TextWrapping="Wrap" />
                                </StackPanel>
                                <ComboBox Grid.Column="1"
                                          Header="绑定模型"
                                          ItemsSource="{x:Bind ProviderOptions}"
                                          DisplayMemberPath="Display"
                                          SelectedItem="{x:Bind SelectedProviderItem, Mode=TwoWay}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <!-- ===== 外观 ===== -->
            <TextBlock Text="外观" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,16,0,4" />
            <ComboBox
                Header="主题"
                SelectedIndex="{x:Bind ViewModel.SelectedThemeIndex, Mode=TwoWay}"
                Width="200">
                <ComboBoxItem Content="跟随系统" />
                <ComboBoxItem Content="浅色" />
                <ComboBoxItem Content="深色" />
            </ComboBox>

            <!-- ===== 双 Agent 简化配置 ===== -->
            <TextBlock Text="双 Agent 简化配置" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,16,0,4" />
            <TextBlock Text="聊天窗口默认使用 ChatAgent，进化后台默认使用 EvolutionAgent。这里配置每个 Agent 的模型、温度与最大工具轮次。"
                       Opacity="0.6" FontSize="13" TextWrapping="Wrap" />

            <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,8">
                <StackPanel Spacing="12">
                    <TextBlock Text="ChatAgent" FontSize="14" FontWeight="SemiBold" />
                    <Grid ColumnDefinitions="*,160,140" ColumnSpacing="12">
                        <ComboBox Header="模型"
                                  ItemsSource="{x:Bind ViewModel.AgentModelOptions, Mode=OneWay}"
                                  DisplayMemberPath="Display"
                                  SelectedValuePath="Value"
                                  SelectedValue="{x:Bind ViewModel.ChatAgentModel, Mode=TwoWay}" />
                        <Slider Grid.Column="1" Header="Temperature"
                                Value="{x:Bind ViewModel.ChatAgentTemperature, Mode=TwoWay}"
                                Minimum="0" Maximum="2" StepFrequency="0.1" />
                        <NumberBox Grid.Column="2" Header="最大工具轮次"
                                   Value="{x:Bind ViewModel.ChatAgentMaxToolIterations, Mode=TwoWay}"
                                   Minimum="1" Maximum="100" SpinButtonPlacementMode="Compact" />
                    </Grid>

                    <TextBlock Text="EvolutionAgent" FontSize="14" FontWeight="SemiBold" Margin="0,8,0,0" />
                    <Grid ColumnDefinitions="*,160,140" ColumnSpacing="12">
                        <ComboBox Header="模型"
                                  ItemsSource="{x:Bind ViewModel.AgentModelOptions, Mode=OneWay}"
                                  DisplayMemberPath="Display"
                                  SelectedValuePath="Value"
                                  SelectedValue="{x:Bind ViewModel.EvolutionAgentModel, Mode=TwoWay}" />
                        <Slider Grid.Column="1" Header="Temperature"
                                Value="{x:Bind ViewModel.EvolutionAgentTemperature, Mode=TwoWay}"
                                Minimum="0" Maximum="2" StepFrequency="0.1" />
                        <NumberBox Grid.Column="2" Header="最大工具轮次"
                                   Value="{x:Bind ViewModel.EvolutionAgentMaxToolIterations, Mode=TwoWay}"
                                   Minimum="1" Maximum="100" SpinButtonPlacementMode="Compact" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== Agent 配置 ===== -->
            <TextBlock Text="高级 Agent 配置" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,16,0,4" />
            <TextBlock Text="如需更细的人设、工具轮次和上下文预算控制，可继续使用高级 Agent 配置。"
                       Opacity="0.6" FontSize="13" TextWrapping="Wrap" />

            <ItemsRepeater ItemsSource="{x:Bind ViewModel.Agents}">
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="models:AgentConfigItem">
                        <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,8">
                            <StackPanel Spacing="8">
                                <Grid ColumnDefinitions="*,Auto,Auto">
                                    <TextBox Header="Agent 名称" Text="{x:Bind Name, Mode=TwoWay}"
                                             PlaceholderText="例如：通用助手" />
                                    <ToggleSwitch Grid.Column="1" Header="默认"
                                                  IsOn="{x:Bind IsDefault, Mode=TwoWay}"
                                                  Margin="12,0,0,0" VerticalAlignment="Bottom" />
                                    <Button Grid.Column="2" VerticalAlignment="Bottom"
                                            Margin="8,0,0,0" Padding="8,6"
                                            ToolTipService.ToolTip="删除"
                                            Click="OnRemoveAgentClick"
                                            Tag="{x:Bind}">
                                        <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                    </Button>
                                </Grid>
                                <TextBox Header="AI 人设" Text="{x:Bind Persona, Mode=TwoWay}"
                                         AcceptsReturn="True" Height="80" TextWrapping="Wrap"
                                         PlaceholderText="描述这个 Agent 的角色和行为..." />
                                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                                    <Slider Header="Temperature"
                                            Value="{x:Bind Temperature, Mode=TwoWay}"
                                            Minimum="0" Maximum="2" StepFrequency="0.1" />
                                    <NumberBox Grid.Column="1" Header="最大工具轮次"
                                               Value="{x:Bind MaxToolIterations, Mode=TwoWay}"
                                               Minimum="1" Maximum="50"
                                               SpinButtonPlacementMode="Compact" />
                                    <NumberBox Grid.Column="2" Header="上下文窗口 (Token)"
                                               Value="{x:Bind ContextWindowBudget, Mode=TwoWay}"
                                               Minimum="4000" Maximum="1000000"
                                               SpinButtonPlacementMode="Compact" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <Button Command="{x:Bind ViewModel.AddAgentCommand}" Margin="0,4,0,0">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE710;" FontSize="14" />
                    <TextBlock Text="添加 Agent" />
                </StackPanel>
            </Button>

            <!-- ===== Ollama 本地模型 ===== -->
            <TextBlock Text="Ollama 本地模型" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,16,0,4" />
            <TextBlock Text="在本机部署开源大模型，完全离线运行，数据不出本地。"
                       Opacity="0.6" FontSize="13" TextWrapping="Wrap" />

            <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,8">
                <StackPanel Spacing="12">

                    <!-- 状态检测 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{x:Bind ViewModel.OllamaStatusText, Mode=OneWay}"
                                   VerticalAlignment="Center" TextWrapping="Wrap" />
                        <Button Grid.Column="1" Command="{x:Bind ViewModel.CheckOllamaCommand}"
                                Margin="12,0,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE72C;" FontSize="14" />
                                <TextBlock Text="检测" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- 一键安装 (未安装时显示) -->
                    <Button Command="{x:Bind ViewModel.InstallOllamaCommand}"
                            Visibility="{x:Bind ViewModel.ShowOllamaInstall, Mode=OneWay}"
                            Style="{StaticResource AccentButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE896;" FontSize="14" />
                            <TextBlock Text="一键安装 Ollama" />
                        </StackPanel>
                    </Button>

                    <!-- 可部署模型搜索 + 部署 (已安装时显示) -->
                    <StackPanel Visibility="{x:Bind ViewModel.IsOllamaInstalled, Mode=OneWay}" Spacing="8">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Header="搜索可部署模型"
                                     Text="{x:Bind ViewModel.AvailableModelSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="输入模型名称搜索..."
                                     HorizontalAlignment="Stretch" />
                            <Button Grid.Column="1" VerticalAlignment="Bottom" Margin="8,0,0,0"
                                    Command="{x:Bind ViewModel.SearchAvailableModelsCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE721;" FontSize="14" />
                                    <TextBlock Text="搜索" />
                                </StackPanel>
                            </Button>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto">
                            <ComboBox ItemsSource="{x:Bind ViewModel.AvailableOllamaModels}"
                                      SelectedItem="{x:Bind ViewModel.SelectedOllamaModel, Mode=TwoWay}"
                                      DisplayMemberPath="Display"
                                      HorizontalAlignment="Stretch" />
                            <Button Grid.Column="1" VerticalAlignment="Bottom" Margin="8,0,0,0"
                                    Command="{x:Bind ViewModel.PullOllamaModelCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE118;" FontSize="14" />
                                    <TextBlock Text="部署模型" />
                                </StackPanel>
                            </Button>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Header="手动输入模型名称"
                                     Text="{x:Bind ViewModel.CustomOllamaModelName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="例如：GLM-4v-9b"
                                     HorizontalAlignment="Stretch" />
                            <Button Grid.Column="1" VerticalAlignment="Bottom" Margin="8,0,0,0"
                                    Command="{x:Bind ViewModel.PullCustomOllamaModelCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE118;" FontSize="14" />
                                    <TextBlock Text="部署" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>

                    <!-- 本地已安装模型 + 接入/卸载 (已安装时显示) -->
                    <Grid Visibility="{x:Bind ViewModel.IsOllamaInstalled, Mode=OneWay}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox Header="本地已安装模型"
                                  ItemsSource="{x:Bind ViewModel.LocalOllamaModels}"
                                  SelectedItem="{x:Bind ViewModel.SelectedLocalModel, Mode=TwoWay}"
                                  DisplayMemberPath="Display"
                                  HorizontalAlignment="Stretch" />
                        <Button Grid.Column="1" VerticalAlignment="Bottom" Margin="8,0,0,0"
                                Command="{x:Bind ViewModel.DeleteOllamaModelCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                <TextBlock Text="卸载" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="2" VerticalAlignment="Bottom" Margin="8,0,0,0"
                                Command="{x:Bind ViewModel.IntegrateOllamaModelCommand}"
                                Style="{StaticResource AccentButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE710;" FontSize="14" />
                                <TextBlock Text="接入为供应商" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- 操作进度 -->
                    <ProgressBar IsIndeterminate="True"
                                 Visibility="{x:Bind ViewModel.IsOllamaOperating, Mode=OneWay}" />
                    <TextBlock Text="{x:Bind ViewModel.OllamaProgress, Mode=OneWay}"
                               FontSize="12" Opacity="0.7" TextWrapping="Wrap" />

                </StackPanel>
            </Border>

            <!-- ===== 保存 ===== -->
            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,16,0,0">
                <Button Command="{x:Bind ViewModel.SaveCommand}"
                        Style="{StaticResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE74E;" FontSize="14" />
                        <TextBlock Text="保存设置" />
                    </StackPanel>
                </Button>
                <TextBlock Text="{x:Bind ViewModel.SaveStatus, Mode=OneWay}"
                           VerticalAlignment="Center" Opacity="0.7" />
            </StackPanel>

            <!-- ===== 关于 ===== -->
            <TextBlock Text="关于" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,16,0,4" />
            <TextBlock Text="{x:Bind ViewModel.VersionInfo}" Opacity="0.7" />
            <HyperlinkButton Content="打开日志目录" Command="{x:Bind ViewModel.OpenLogsFolderCommand}" />

        </StackPanel>
    </ScrollViewer>
</Page>
