<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OwnerAI.Host.Desktop.Views.SkillsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OwnerAI.Host.Desktop.Views">

    <Page.Resources>
        <local:SkillTemplateSelector x:Key="SkillSelector">

            <!-- ═══ 分支根节点（分类标题）═══ -->
            <local:SkillTemplateSelector.HeaderTemplate>
                <DataTemplate>
                    <Grid Margin="0,24,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- 树干 + 分支根圆点 -->
                        <Grid>
                            <Rectangle Width="2" Fill="{StaticResource OwnerAIPrimaryBrush}"
                                       VerticalAlignment="Stretch" HorizontalAlignment="Center"
                                       Opacity="0.2" Margin="0,20,0,-4" />
                            <Ellipse Width="14" Height="14"
                                     Fill="{StaticResource OwnerAIPrimaryBrush}"
                                     HorizontalAlignment="Center" VerticalAlignment="Top"
                                     Margin="0,5,0,0" />
                        </Grid>

                        <!-- 分类名 + 计数 -->
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="{Binding Category}"
                                           Style="{StaticResource SubtitleTextBlockStyle}"
                                           FontWeight="Bold" />
                                <Border Background="{StaticResource OwnerAIPrimaryBrush}"
                                        CornerRadius="10" Padding="10,3" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Count}" FontSize="11"
                                               Foreground="White" FontWeight="SemiBold" />
                                </Border>
                                <Border Background="#F59E0B" CornerRadius="10" Padding="8,3"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding GapCount, Converter={StaticResource IntToVisibility}}">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <FontIcon Glyph="&#xE945;" FontSize="10" Foreground="White" />
                                        <TextBlock Text="{Binding GapCount}" FontSize="11"
                                                   Foreground="White" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </local:SkillTemplateSelector.HeaderTemplate>

            <!-- ═══ 已激活技能节点 ═══ -->
            <local:SkillTemplateSelector.CardTemplate>
                <DataTemplate>
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- 树干竖线 + 水平分支线 + 节点圆点 -->
                        <Grid>
                            <Rectangle Width="2" Fill="{StaticResource OwnerAIPrimaryBrush}"
                                       VerticalAlignment="Stretch" HorizontalAlignment="Center"
                                       Opacity="0.15" />
                            <Rectangle Width="16" Height="2"
                                       Fill="{StaticResource OwnerAIPrimaryBrush}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       Opacity="0.3" />
                            <Ellipse Width="8" Height="8"
                                     Fill="{Binding SecurityColor, Converter={StaticResource SecurityColorToBrush}}"
                                     HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>

                        <!-- 技能卡片 -->
                        <Border Grid.Column="1" Margin="4,2,0,2"
                                CornerRadius="10" Padding="14,12"
                                BorderBrush="{Binding IsDuplicate, Converter={StaticResource DuplicateBorderBrush}}"
                                BorderThickness="2"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                Opacity="{Binding IsEnabled, Converter={StaticResource SkillEnabledToOpacity}}">
                            <Grid RowDefinitions="Auto,Auto">
                                <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                                    <!-- 图标（带主色边框） -->
                                    <Border Grid.Column="0" Width="42" Height="42"
                                            CornerRadius="12" VerticalAlignment="Top"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                            BorderBrush="{StaticResource OwnerAIPrimaryBrush}"
                                            BorderThickness="1.5">
                                        <FontIcon Glyph="{Binding Glyph}" FontSize="18"
                                                  Foreground="{StaticResource OwnerAIPrimaryBrush}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>

                                    <!-- 名称 + 描述 -->
                                    <StackPanel Grid.Column="1" Spacing="2" Margin="12,0,0,0">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontWeight="SemiBold" FontSize="14" />
                                            <TextBlock Text="{Binding Subtitle}"
                                                       FontSize="11" Opacity="0.4"
                                                       VerticalAlignment="Center"
                                                       FontFamily="Consolas" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding Description}"
                                                   FontSize="12" Opacity="0.7"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxLines="2" TextWrapping="Wrap" />
                                    </StackPanel>

                                    <!-- 安全等级标签 -->
                                    <Border Grid.Column="2" VerticalAlignment="Top"
                                            CornerRadius="4" Padding="8,3" Margin="8,0"
                                            Background="{Binding SecurityColor, Converter={StaticResource SecurityColorToBrush}}">
                                        <TextBlock Text="{Binding SecurityLabel}"
                                                   FontSize="10" Foreground="White" />
                                    </Border>

                                    <!-- 删除按钮（仅外部技能） -->
                                    <Button Grid.Column="3" VerticalAlignment="Top"
                                            Visibility="{Binding IsExternal, Converter={StaticResource BoolToVisibility}}"
                                            Click="DeleteSkill_Click"
                                            Padding="6" Margin="4,0"
                                            Background="Transparent" BorderThickness="0"
                                            ToolTipService.ToolTip="移除此技能">
                                        <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="#EF4444" />
                                    </Button>

                                    <!-- 启用/禁用开关 -->
                                    <ToggleSwitch Grid.Column="4" VerticalAlignment="Top"
                                                  IsOn="{Binding IsEnabled, Mode=TwoWay}"
                                                  MinWidth="0" MinHeight="0"
                                                  OnContent="" OffContent=""
                                                  Toggled="SkillToggle_Toggled" />
                                </Grid>

                                <!-- 重复提醒 -->
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="4"
                                            Margin="54,4,0,0"
                                            Visibility="{Binding IsDuplicate, Converter={StaticResource BoolToVisibility}}">
                                    <FontIcon Glyph="&#xE7BA;" FontSize="12" Foreground="#EF4444" />
                                    <TextBlock Text="⚠ 技能名称重复，可能导致冲突"
                                               FontSize="11" Foreground="#EF4444" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </DataTemplate>
            </local:SkillTemplateSelector.CardTemplate>

            <!-- ═══ 进化缺口节点（待进化 / 进化中 / 已解决）═══ -->
            <local:SkillTemplateSelector.GapTemplate>
                <DataTemplate>
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- 树干 + 空心连接点（表示未解锁） -->
                        <Grid>
                            <Rectangle Width="2" Fill="{StaticResource OwnerAIAccentBrush}"
                                       VerticalAlignment="Stretch" HorizontalAlignment="Center"
                                       Opacity="0.12" />
                            <Rectangle Width="16" Height="2"
                                       Fill="{Binding StateColor, Converter={StaticResource SecurityColorToBrush}}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       Opacity="0.4" />
                            <Ellipse Width="10" Height="10"
                                     Stroke="{Binding StateColor, Converter={StaticResource SecurityColorToBrush}}"
                                     StrokeThickness="2" Fill="Transparent"
                                     HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>

                        <!-- 进化缺口卡片 -->
                        <Border Grid.Column="1" Margin="4,2,0,2"
                                CornerRadius="10" Padding="14,12"
                                BorderBrush="{Binding StateColor, Converter={StaticResource SecurityColorToBrush}}"
                                BorderThickness="1.5"
                                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                Opacity="0.85">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <!-- 状态图标 -->
                                <Border Grid.Column="0" Width="42" Height="42"
                                        CornerRadius="12" VerticalAlignment="Top"
                                        BorderBrush="{Binding StateColor, Converter={StaticResource SecurityColorToBrush}}"
                                        BorderThickness="1.5"
                                        Background="Transparent">
                                    <FontIcon Glyph="{Binding Glyph}" FontSize="18"
                                              Foreground="{Binding StateColor, Converter={StaticResource SecurityColorToBrush}}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>

                                <!-- 描述 + 优先级 + 尝试次数 -->
                                <StackPanel Grid.Column="1" Spacing="4" Margin="12,0,0,0">
                                    <TextBlock Text="{Binding Description}"
                                               FontWeight="SemiBold" FontSize="13"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="2" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding StatusDetailText}"
                                               FontSize="11" Opacity="0.72"
                                               TextWrapping="Wrap" />
                                    <StackPanel Orientation="Horizontal" Spacing="14">
                                        <StackPanel Orientation="Horizontal" Spacing="3">
                                            <FontIcon Glyph="&#xE735;" FontSize="11"
                                                      Foreground="#F59E0B" />
                                            <TextBlock FontSize="11" Opacity="0.7">
                                                <Run Text="P" /><Run Text="{Binding Priority}" />
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="3">
                                            <FontIcon Glyph="&#xE72C;" FontSize="11"
                                                      Opacity="0.5" />
                                            <TextBlock FontSize="11" Opacity="0.6">
                                                <Run Text="尝试 " /><Run Text="{Binding AttemptCount}" /><Run Text=" 次" />
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Resolution}" FontSize="11"
                                                   Opacity="0.5" MaxLines="1"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Border CornerRadius="4" Padding="8,2"
                                                Background="{Binding StateColor, Converter={StaticResource SecurityColorToBrush}}">
                                            <TextBlock Text="{Binding PlanProgressText}"
                                                       FontSize="10" Foreground="White"
                                                       FontWeight="SemiBold" />
                                        </Border>
                                        <TextBlock Text="{Binding NextStepText}"
                                                   FontSize="11" Opacity="0.6"
                                                   MaxLines="1" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </StackPanel>

                                <!-- 状态标签 -->
                                <Border Grid.Column="2" VerticalAlignment="Top"
                                        CornerRadius="4" Padding="8,3" Margin="8,0"
                                        Background="{Binding StateColor, Converter={StaticResource SecurityColorToBrush}}">
                                    <TextBlock Text="{Binding StateLabel}"
                                               FontSize="10" Foreground="White"
                                               FontWeight="SemiBold" />
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </DataTemplate>
            </local:SkillTemplateSelector.GapTemplate>

        </local:SkillTemplateSelector>
    </Page.Resources>

    <Grid RowDefinitions="Auto,*" Padding="24">

        <!-- ═══ 页面标题 + 技能树统计 ═══ -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <FontIcon Glyph="&#xE9D9;" FontSize="24"
                              Foreground="{StaticResource OwnerAIPrimaryBrush}" />
                    <TextBlock Text="技能树" Style="{StaticResource TitleTextBlockStyle}"
                               FontWeight="Bold" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,2,0,0">
                    <!-- 已激活 -->
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <Ellipse Width="8" Height="8" Fill="#22C55E" VerticalAlignment="Center" />
                        <TextBlock FontSize="12" Opacity="0.8">
                            <Run Text="已激活 " />
                            <Run Text="{x:Bind ViewModel.EnabledCount, Mode=OneWay}" FontWeight="SemiBold" />
                            <Run Text=" / " />
                            <Run Text="{x:Bind ViewModel.TotalSkillCount, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>

                    <!-- 内置 -->
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <FontIcon Glyph="&#xE945;" FontSize="11"
                                  Foreground="{StaticResource OwnerAIPrimaryBrush}" />
                        <TextBlock FontSize="12" Opacity="0.7">
                            <Run Text="内置 " />
                            <Run Text="{x:Bind ViewModel.BuiltInCount, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>

                    <!-- 外部 -->
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <FontIcon Glyph="&#xE946;" FontSize="11" Foreground="#8B5CF6" />
                        <TextBlock FontSize="12" Opacity="0.7">
                            <Run Text="外部 " />
                            <Run Text="{x:Bind ViewModel.ExternalCount, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>

                    <TextBlock Text="|" FontSize="12" Opacity="0.2" VerticalAlignment="Center" />

                    <!-- 进化中 -->
                    <StackPanel Orientation="Horizontal" Spacing="5"
                                Visibility="{x:Bind ViewModel.EvolvingCount, Mode=OneWay, Converter={StaticResource IntToVisibility}}">
                        <Ellipse Width="8" Height="8" Fill="#3B82F6" VerticalAlignment="Center" />
                        <TextBlock FontSize="12" Foreground="#3B82F6">
                            <Run Text="进化中 " />
                            <Run Text="{x:Bind ViewModel.EvolvingCount, Mode=OneWay}" FontWeight="SemiBold" />
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="5"
                                Visibility="{x:Bind ViewModel.PlannedGapCount, Mode=OneWay, Converter={StaticResource IntToVisibility}}">
                        <FontIcon Glyph="&#xE8A5;" FontSize="11" Foreground="#6366F1" />
                        <TextBlock FontSize="12" Foreground="#6366F1">
                            <Run Text="已有计划 " />
                            <Run Text="{x:Bind ViewModel.PlannedGapCount, Mode=OneWay}" FontWeight="SemiBold" />
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="5"
                                Visibility="{x:Bind ViewModel.PlanningCount, Mode=OneWay, Converter={StaticResource IntToVisibility}}">
                        <Ellipse Width="8" Height="8" Fill="#F59E0B" VerticalAlignment="Center" />
                        <TextBlock FontSize="12" Foreground="#F59E0B">
                            <Run Text="规划中 " />
                            <Run Text="{x:Bind ViewModel.PlanningCount, Mode=OneWay}" FontWeight="SemiBold" />
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="5"
                                Visibility="{x:Bind ViewModel.ImplementingCount, Mode=OneWay, Converter={StaticResource IntToVisibility}}">
                        <Ellipse Width="8" Height="8" Fill="#3B82F6" VerticalAlignment="Center" />
                        <TextBlock FontSize="12" Foreground="#3B82F6">
                            <Run Text="实施中 " />
                            <Run Text="{x:Bind ViewModel.ImplementingCount, Mode=OneWay}" FontWeight="SemiBold" />
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="5"
                                Visibility="{x:Bind ViewModel.VerifyingCount, Mode=OneWay, Converter={StaticResource IntToVisibility}}">
                        <Ellipse Width="8" Height="8" Fill="#8B5CF6" VerticalAlignment="Center" />
                        <TextBlock FontSize="12" Foreground="#8B5CF6">
                            <Run Text="验收中 " />
                            <Run Text="{x:Bind ViewModel.VerifyingCount, Mode=OneWay}" FontWeight="SemiBold" />
                        </TextBlock>
                    </StackPanel>

                    <!-- 待进化 -->
                    <StackPanel Orientation="Horizontal" Spacing="5"
                                Visibility="{x:Bind ViewModel.EvolutionGapCount, Mode=OneWay, Converter={StaticResource IntToVisibility}}">
                        <Ellipse Width="8" Height="8" Fill="#F59E0B" VerticalAlignment="Center" />
                        <TextBlock FontSize="12" Foreground="#F59E0B">
                            <Run Text="待进化 " />
                            <Run Text="{x:Bind ViewModel.EvolutionGapCount, Mode=OneWay}" FontWeight="SemiBold" />
                        </TextBlock>
                    </StackPanel>

                    <!-- 已解决 -->
                    <StackPanel Orientation="Horizontal" Spacing="5"
                                Visibility="{x:Bind ViewModel.ResolvedCount, Mode=OneWay, Converter={StaticResource IntToVisibility}}">
                        <FontIcon Glyph="&#xE73E;" FontSize="11" Foreground="#22C55E" />
                        <TextBlock FontSize="12" Opacity="0.7">
                            <Run Text="已解决 " />
                            <Run Text="{x:Bind ViewModel.ResolvedCount, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>

                    <!-- 重复警告 -->
                    <StackPanel Orientation="Horizontal" Spacing="4"
                                Visibility="{x:Bind ViewModel.DuplicateCount, Mode=OneWay, Converter={StaticResource IntToVisibility}}">
                        <FontIcon Glyph="&#xE7BA;" FontSize="11" Foreground="#EF4444" />
                        <TextBlock FontSize="12" Foreground="#EF4444">
                            <Run Text="重复 " />
                            <Run Text="{x:Bind ViewModel.DuplicateCount, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <!-- 操作按钮 -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                        VerticalAlignment="Center">
                <Button Command="{x:Bind ViewModel.RefreshCommand}"
                        ToolTipService.ToolTip="刷新技能树">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE72C;" FontSize="14" />
                        <TextBlock Text="刷新" />
                    </StackPanel>
                </Button>
                <Button Click="ScanFolder_Click"
                        Style="{StaticResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE8B7;" FontSize="14" />
                        <TextBlock Text="扫描文件夹" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ═══ 技能树主体 ═══ -->
        <ScrollViewer Grid.Row="1" Margin="0,16,0,0">
            <ItemsRepeater ItemsSource="{x:Bind ViewModel.FlatItems}"
                           ItemTemplate="{StaticResource SkillSelector}">
                <ItemsRepeater.Layout>
                    <StackLayout Spacing="0" />
                </ItemsRepeater.Layout>
            </ItemsRepeater>
        </ScrollViewer>
    </Grid>
</Page>
