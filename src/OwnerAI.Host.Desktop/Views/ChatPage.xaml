<?xml version="1.0" encoding="utf-8"?>
<Page
	x:Class="OwnerAI.Host.Desktop.Views.ChatPage"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:models="using:OwnerAI.Host.Desktop.Models"
	NavigationCacheMode="Required">

	<Grid RowDefinitions="Auto,*,Auto,Auto,Auto">

		<!-- 错误提示横幅 -->
		<InfoBar
			Grid.Row="0"
			IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
			Severity="Error"
			Title="调用失败"
			Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
			IsClosable="True"
			CloseButtonCommand="{x:Bind ViewModel.DismissErrorCommand}" />

		<!-- 消息列表 -->
		<ListView
			x:Name="MessageList"
			Grid.Row="1"
			Padding="16,8"
			ItemsSource="{x:Bind ViewModel.Messages}"
			SelectionMode="None">
			<ListView.ItemTemplate>
					<DataTemplate x:DataType="models:ChatBubble">
						<Grid Margin="0,6" HorizontalAlignment="{x:Bind IsUser, Converter={StaticResource BoolToAlignment}}">
							<!-- 聊天气泡主容器 -->
							<Border
								MaxWidth="680" MinWidth="120"
								CornerRadius="14"
								Background="{x:Bind Role, Converter={StaticResource ChatRoleToBrush}}"
								BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
								BorderThickness="1"
								Padding="16,14">
								<StackPanel>

									<!-- 模型标识头部 — 仅非用户气泡显示 -->
									<StackPanel
										Orientation="Horizontal" Spacing="6"
										Margin="0,0,0,10"
										Opacity="0.8"
										Visibility="{x:Bind ShowModelHeader}">
										<FontIcon Glyph="{x:Bind ModelGlyph}" FontSize="13" Foreground="White" />
										<TextBlock Text="{x:Bind ModelName}" FontSize="12" FontWeight="SemiBold" Foreground="White" />
									</StackPanel>

									<!-- 后台任务阶段标识 + 流水线 -->
									<StackPanel Margin="0,0,0,10"
											Visibility="{x:Bind BackgroundTaskStageVisibility}">
                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
											<Border Background="{x:Bind TaskStageBrush}"
													CornerRadius="6"
													Padding="10,4"
													HorizontalAlignment="Left">
												<TextBlock Text="{x:Bind TaskStageLabel}"
													   FontSize="11"
													   FontWeight="SemiBold"
													   Foreground="White" />
											</Border>
											<Border Background="#111827"
													BorderBrush="#374151"
													BorderThickness="1"
													CornerRadius="6"
													Padding="10,4"
													Visibility="{x:Bind BackgroundGapIdVisibility}">
												<TextBlock Text="{x:Bind BackgroundGapIdText}"
													   FontSize="11"
													   FontFamily="Consolas"
													   Foreground="#D1D5DB" />
											</Border>
										</StackPanel>
										<StackPanel Orientation="Horizontal" Spacing="6">
											<Border Background="{x:Bind PlanningStageBrush}" CornerRadius="6" Padding="8,3">
												<TextBlock Text="规划" FontSize="10" FontWeight="{x:Bind PlanningStageWeight}" Foreground="White" />
											</Border>
											<TextBlock Text="→" Foreground="#9CA3AF" VerticalAlignment="Center" />
											<Border Background="{x:Bind ExecutionStageBrush}" CornerRadius="6" Padding="8,3">
												<TextBlock Text="执行" FontSize="10" FontWeight="{x:Bind ExecutionStageWeight}" Foreground="White" />
											</Border>
											<TextBlock Text="→" Foreground="#9CA3AF" VerticalAlignment="Center" />
											<Border Background="{x:Bind VerificationStageBrush}" CornerRadius="6" Padding="8,3">
												<TextBlock Text="验收" FontSize="10" FontWeight="{x:Bind VerificationStageWeight}" Foreground="White" />
											</Border>
										</StackPanel>
									</StackPanel>

									<!-- 工具调用 (思考过程) -->
									<ItemsRepeater ItemsSource="{x:Bind ToolCalls}">
										<ItemsRepeater.Layout>
											<StackLayout Spacing="0" />
										</ItemsRepeater.Layout>
										<ItemsRepeater.ItemTemplate>
											<DataTemplate x:DataType="models:ToolCallDisplay">
												<Grid Margin="0,0,0,8">
													<Grid.ColumnDefinitions>
														<ColumnDefinition Width="Auto" />
														<ColumnDefinition Width="*" />
													</Grid.ColumnDefinitions>

													<!-- 左侧指示器与连接线 -->
													<StackPanel Grid.Column="0" Margin="0,4,12,0" Width="16" Spacing="4">
														<ProgressRing IsActive="{x:Bind IsRunning, Mode=OneWay}" Width="14" Height="14" Foreground="#9CA3AF" Visibility="{x:Bind IsRunning, Mode=OneWay}"/>
														<FontIcon Glyph="&#xE90F;" FontSize="14" Foreground="#10B981" Visibility="{x:Bind IsFinished, Mode=OneWay}"/>
														<Rectangle Width="1" Height="12" Fill="#4B5563" HorizontalAlignment="Center" Opacity="0.5" />
													</StackPanel>

													<!-- 右侧详情 -->
													<StackPanel Grid.Column="1" Padding="0,2,0,6">
														<TextBlock FontSize="12" Foreground="#D1D5DB" FontWeight="SemiBold">
															<Run Text="工具调用: " />
															<Run Text="{x:Bind ToolName, Mode=OneWay}" />
														</TextBlock>
														<!-- 参数概要 -->
														<TextBlock FontSize="11" Margin="0,4,0,0" Text="{x:Bind Parameters, Mode=OneWay}" Foreground="#9CA3AF" TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis" />
														<TextBlock FontSize="10" Margin="0,4,0,0" Text="{x:Bind Duration, Mode=OneWay}" Foreground="#6B7280" />
													</StackPanel>
												</Grid>
											</DataTemplate>
										</ItemsRepeater.ItemTemplate>
									</ItemsRepeater>

									<!-- 消息文本 — 流式输出中显示纯文本 -->
									<TextBlock
										Text="{x:Bind Text, Mode=OneWay}"
										TextWrapping="Wrap"
										IsTextSelectionEnabled="True"
										Foreground="White"
										LineHeight="22"
										Visibility="{x:Bind ShowPlainText, Mode=OneWay}" />

									<!-- 富文本内容 — 流式结束后将文字、图片、视频、来源交错显示 -->
									<ItemsRepeater
										ItemsSource="{x:Bind ContentSegments}"
										Visibility="{x:Bind ShowRichContent, Mode=OneWay}">
										<ItemsRepeater.Layout>
											<StackLayout Spacing="0" />
										</ItemsRepeater.Layout>
										<ItemsRepeater.ItemTemplate>
											<DataTemplate x:DataType="models:ContentSegment">
												<Grid>
													<!-- 文本段 -->
													<TextBlock
														Text="{x:Bind Content, Mode=OneWay}"
														TextWrapping="Wrap"
														IsTextSelectionEnabled="True"
														Foreground="White"
														LineHeight="22"
														Visibility="{x:Bind IsText, Mode=OneWay}" />

													<!-- 图片段 -->
													<Border
														CornerRadius="8"
														MaxWidth="360" MaxHeight="240"
														HorizontalAlignment="Left"
														Margin="0,8"
														BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
														BorderThickness="1"
														Visibility="{x:Bind IsImage, Mode=OneWay}">
														<Image
															Source="{x:Bind ImageUrl, Converter={StaticResource StringToImageSource}, Mode=OneWay}"
															Stretch="Uniform" />
													</Border>

													<!-- 视频引用 — 点击在浏览器中跨平台打开 -->
													<Border
														CornerRadius="8" Padding="12,10"
														Margin="0,8"
														Background="#262626"
														BorderBrush="#404040" BorderThickness="1"
														HorizontalAlignment="Left"
														Visibility="{x:Bind IsVideo, Mode=OneWay}">
														<HyperlinkButton
															NavigateUri="{x:Bind NavigateUri, Mode=OneWay}"
															Padding="0" Background="Transparent" BorderThickness="0">
															<StackPanel Orientation="Horizontal" Spacing="8">
																<FontIcon Glyph="&#xE714;" FontSize="16" Foreground="#60A5FA" />
																<TextBlock
																	Text="{x:Bind DisplayText, Mode=OneWay}"
																	Foreground="#93C5FD" FontSize="13"
																	VerticalAlignment="Center" />
															</StackPanel>
														</HyperlinkButton>
													</Border>

													<!-- 来源链接 -->
													<Border
														CornerRadius="6" Padding="8,4"
														Margin="0,6,0,6"
														Background="#1F2937"
														HorizontalAlignment="Left"
														Visibility="{x:Bind IsLink, Mode=OneWay}">
														<HyperlinkButton
															NavigateUri="{x:Bind NavigateUri, Mode=OneWay}"
															Padding="0" Background="Transparent" BorderThickness="0">
															<StackPanel Orientation="Horizontal" Spacing="6">
																<FontIcon Glyph="&#xE71B;" FontSize="12" Foreground="#9CA3AF" />
																<TextBlock
																	Text="{x:Bind DisplayText, Mode=OneWay}"
																	Foreground="#D1D5DB" FontSize="12" />
															</StackPanel>
														</HyperlinkButton>
													</Border>
												</Grid>
											</DataTemplate>
										</ItemsRepeater.ItemTemplate>
									</ItemsRepeater>

									<!-- 附件展示区 (独立的文档等) -->
									<ItemsRepeater
										ItemsSource="{x:Bind Attachments}"
										Margin="0,8,0,0">
										<ItemsRepeater.Layout>
											<StackLayout Spacing="0" />
										</ItemsRepeater.Layout>
										<ItemsRepeater.ItemTemplate>
											<DataTemplate x:DataType="models:AttachmentDisplay">
												<Border
													CornerRadius="8" Margin="0,4,0,0"
													Background="#2A2A2A"
													BorderBrush="#404040"
													BorderThickness="1" Padding="12,8">
													<StackPanel Orientation="Horizontal" Spacing="8">
														<FontIcon Glyph="&#xE8A5;" FontSize="16" Foreground="#D1D5DB" />
														<TextBlock Text="{x:Bind FileName, Mode=OneWay}" Foreground="White" FontSize="13"
																   VerticalAlignment="Center" />
													</StackPanel>
												</Border>
											</DataTemplate>
										</ItemsRepeater.ItemTemplate>
									</ItemsRepeater>

								</StackPanel>
							</Border>
						</Grid>
					</DataTemplate>
			</ListView.ItemTemplate>
			<ListView.ItemContainerStyle>
				<Style TargetType="ListViewItem">
					<Setter Property="HorizontalContentAlignment" Value="Stretch" />
					<Setter Property="Padding" Value="0" />
					<Setter Property="MinHeight" Value="0" />
				</Style>
			</ListView.ItemContainerStyle>
		</ListView>

		<!-- 待发送附件预览条 -->
		<ItemsRepeater
			Grid.Row="2"
			ItemsSource="{x:Bind ViewModel.PendingAttachments}"
			Margin="16,0"
			Visibility="{x:Bind ViewModel.HasPendingAttachments, Mode=OneWay}">
			<ItemsRepeater.Layout>
				<StackLayout Orientation="Horizontal" Spacing="8" />
			</ItemsRepeater.Layout>
			<ItemsRepeater.ItemTemplate>
				<DataTemplate x:DataType="models:AttachmentDisplay">
					<Grid Padding="8,4" CornerRadius="8"
						  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="Auto" />
						</Grid.ColumnDefinitions>
						<FontIcon Grid.Column="0" Glyph="&#xE8A5;" FontSize="14" VerticalAlignment="Center" />
						<TextBlock Grid.Column="1" Text="{x:Bind FileName}" FontSize="12"
								   VerticalAlignment="Center" Margin="6,0" MaxWidth="120"
								   TextTrimming="CharacterEllipsis" />
						<Button Grid.Column="2" Padding="2" Background="Transparent"
								CommandParameter="{x:Bind}"
								ToolTipService.ToolTip="移除">
							<FontIcon Glyph="&#xE711;" FontSize="10" />
						</Button>
					</Grid>
				</DataTemplate>
			</ItemsRepeater.ItemTemplate>
		</ItemsRepeater>

		<!-- 输入区域 -->
		<Grid Grid.Row="3" Padding="16,8">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="Auto" />
			</Grid.ColumnDefinitions>
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
			</Grid.RowDefinitions>
         <Border
				Grid.Row="1" Grid.Column="0"
				Background="#1F2937"
				CornerRadius="6"
				Padding="10,4"
				VerticalAlignment="Center">
				<StackPanel Orientation="Horizontal" Spacing="6">
					<FontIcon Glyph="&#xE99A;" FontSize="12" Foreground="#93C5FD" />
					<TextBlock Text="{x:Bind ViewModel.ChatAgentDisplayName, Mode=OneWay}"
							   FontSize="11" FontWeight="SemiBold" Foreground="#DBEAFE" />
				</StackPanel>
			</Border>
			<Button
				Grid.Row="0" Grid.Column="0"
				Margin="0,0,8,0"
				Command="{x:Bind ViewModel.PickAttachmentCommand}"
				ToolTipService.ToolTip="添加附件 (图片/视频/文档)"
				Padding="8">
				<FontIcon Glyph="&#xE723;" />
			</Button>
			<TextBox
				x:Name="InputBox"
				Grid.Row="0" Grid.Column="1"
				PlaceholderText="输入消息... (Enter 发送)"
				Text="{x:Bind ViewModel.InputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
				AcceptsReturn="False"
				KeyDown="InputBox_KeyDown"
				VerticalAlignment="Center" />
			<Button
				Grid.Row="0" Grid.Column="2"
				Margin="8,0,0,0"
				Command="{x:Bind ViewModel.SendCommand}"
				Style="{StaticResource AccentButtonStyle}"
				ToolTipService.ToolTip="发送">
				<FontIcon Glyph="&#xE724;" />
			</Button>
			<Button
				Grid.Row="0" Grid.Column="3"
				Margin="4,0,0,0"
				Command="{x:Bind ViewModel.CancelCommand}"
				Visibility="{x:Bind ViewModel.IsProcessing, Mode=OneWay}"
				ToolTipService.ToolTip="取消">
				<FontIcon Glyph="&#xE711;" />
			</Button>

			<!-- 进化状态指示器 -->
			<StackPanel
				Grid.Row="1" Grid.Column="1"
				Margin="0,6,0,0"
				Orientation="Horizontal"
				Spacing="8"
				Visibility="{x:Bind ViewModel.ShowEvolutionIndicator, Mode=OneWay}"
				ToolTipService.ToolTip="{x:Bind ViewModel.EvolutionSummary, Mode=OneWay}">
				<ProgressRing
					IsActive="{x:Bind ViewModel.IsEvolutionActive, Mode=OneWay}"
					Width="12" Height="12"
					Foreground="#10B981" />
              <TextBlock
					Text="{x:Bind ViewModel.EvolutionAgentDisplayName, Mode=OneWay}"
					FontSize="11"
					FontWeight="SemiBold"
					Foreground="#10B981"
					VerticalAlignment="Center" />
				<TextBlock
					Text="能力形成中..."
					FontSize="11"
					FontWeight="SemiBold"
					Foreground="#10B981"
					VerticalAlignment="Center" />
				<TextBlock
					Text="{x:Bind ViewModel.EvolutionPhase, Mode=OneWay}"
					FontSize="11"
					Foreground="#10B981"
					Opacity="0.8"
					VerticalAlignment="Center"
					MaxWidth="300"
					TextTrimming="CharacterEllipsis" />
			</StackPanel>
		</Grid>

		<!-- 状态栏 -->
		<Grid Grid.Row="4" Padding="16,4" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
			<StackPanel Orientation="Horizontal" Spacing="8">
				<ProgressRing
					IsActive="{x:Bind ViewModel.IsProcessing, Mode=OneWay}"
					Width="14" Height="14" />
				<TextBlock
					Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
					FontSize="12"
					Opacity="0.7" />
			</StackPanel>

			<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="2">
				<Button
					Command="{x:Bind ViewModel.TriggerEvolutionCommand}"
					ToolTipService.ToolTip="触发自我进化"
					Padding="4"
					Background="Transparent">
					<FontIcon Glyph="&#xE81C;" FontSize="14" />
				</Button>
				<Button
					Command="{x:Bind ViewModel.ClearChatCommand}"
					ToolTipService.ToolTip="清空对话"
					Padding="4"
					Background="Transparent">
					<FontIcon Glyph="&#xE74D;" FontSize="14" />
				</Button>
			</StackPanel>
		</Grid>
	</Grid>
</Page>
