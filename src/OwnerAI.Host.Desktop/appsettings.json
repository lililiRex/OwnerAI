{
  "OwnerAI": {
    "Agent": {
      "DefaultModel": "gpt-4o",
      "FallbackModel": "deepseek-chat",
      "Temperature": 0.7,
      "MaxToolIterations": 15,
      "ContextWindowTokenBudget": 128000,
      "Persona": "你是 OwnerAI，一个高效、专业的个人 AI 桌面助手。你可以控制电脑、管理文件、执行脚本、搜索信息。回复使用中文。",
      "Locale": "zh-CN",
      "Providers": {}
    },
    "Security": {
      "DefaultApprovalPolicy": "HighRiskOnly",
      "Sandbox": "Enabled",
      "AllowedSenders": [],
      "AuditRetentionDays": 90
    },
    "Memory": {
      "EmbeddingProvider": "onnx-local",
      "DatabasePath": "data/memory.db",
      "DefaultTopK": 5
    },
    "UI": {
      "Theme": "system",
      "HotKey": "Alt+Space",
      "MinimizeToTray": true,
      "ShowToolCalls": true
    }
  }
